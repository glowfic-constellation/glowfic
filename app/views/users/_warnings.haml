-# locals: ( user: )

- unless user.content_warnings.empty?
  - content_for :flashes do
    .flash.error
      %details
        %summary
          = image_tag "icons/exclamation.png".freeze, class: 'vmid'.freeze, alt: ''
          This author has set some general content warnings which might apply to their posts even when not otherwise warned.
        %ul
          - user.content_warnings.each do |warning|
            %li= link_to warning.name, tag_path(warning)
