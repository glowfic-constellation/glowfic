- content_for :breadcrumbs do
  = link_to 'Skins', skins_path
  &raquo;
  %b= @skin.name

%span.time-loaded= pretty_time(DateTime.now.in_time_zone)

%table
  %thead
    %tr
      %th.table-title{colspan: 2}
        = @skin.name
        - if @skin.editable_by?(current_user)
          = link_to edit_skin_path(@skin) do
            .link-box.action-new Edit
  %tbody
    %tr
      %th.sub.width-150 By
      %td.padding-5= user_link(@skin.user)
    %tr
      %th.sub.width-150 Shared
      %td.padding-5= @skin.public? ? 'Public' : 'Private'
    - if @skin.description.present?
      %tr
        %th.sub.width-150 Description
        %td.padding-5= @skin.description
    %tr
      %th.sub.width-150 CSS
      %td.padding-5
        %pre.skin-css= @skin.css

- if logged_in?
  .centered.padding-10
    - if current_user.skin_id == @skin.id
      = link_to 'Turn off', clear_skin_path, method: :delete, class: 'button'
    - else
      = link_to 'Use this skin', use_skin_path(@skin), method: :post, class: 'button'
    - unless @skin.editable_by?(current_user)
      = link_to 'Copy to my skins', fork_skin_path(@skin), method: :post, class: 'button'
