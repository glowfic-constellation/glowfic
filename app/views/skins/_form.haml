= form_for @skin do |f|
  .form-table
    .editor-title= @skin.persisted? ? 'Edit Skin' : 'New Skin'
    %div
      .sub= f.label :name
      %div{class: cycle('even', 'odd')}= f.text_field :name, placeholder: 'Skin name'
    %div
      .sub= f.label :description
      %div{class: cycle('even', 'odd')}= f.text_field :description, placeholder: 'Optional description'
    %div
      .sub Sharing
      .checkbox-field{class: cycle('even', 'odd')}
        = f.check_box :public
        = f.label :public, 'List this skin publicly in the gallery'
    %div
      .sub= f.label :css, 'CSS'
      %div{class: cycle('even', 'odd')}
        = f.text_area :css, id: 'skin_css', rows: 20, placeholder: '.post-container { background-color: #222; }'
        .details
          Custom CSS applies to the whole page. For safety it is sanitized before
          use: external resources, scripts, fixed/sticky positioning and
          %code !important
          are stripped, and content warnings always stay visible.
    .form-table-ender= f.submit @skin.persisted? ? 'Update' : 'Create', class: 'button'
